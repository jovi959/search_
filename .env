# --- LM Studio / OpenAI-compatible API ---

# OpenAI-compatible endpoint (LM Studio)
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# API key — LM Studio default is "lm-studio"
LM_STUDIO_API_KEY=lm-studio

# Model used by the agent for reasoning and tool calls
AGENT_MODEL=locooperator-4b@q8_0

# Model Promptfoo uses to grade LLM-rubric test assertions
GRADER_MODEL=locooperator-4b@q8_0


# --- Browser ---

# true = no visible browser window, false = visible
HEADLESS=false

# Custom Chrome user agent string. Empty = Chrome default
USER_AGENT=


# --- MCP server ---

# Bind address (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
MCP_HOST=0.0.0.0

# Port the MCP server listens on
MCP_PORT=8000


# --- Agent behaviour ---

# Seconds to sleep between tool calls (0 = no delay)
TOOL_CALL_DELAY=0

# Seconds CDP stays detached during search navigation.
# 0 = plain driver.get(), >0 = driver.uc_open_with_reconnect(url, reconnect_time)
STEALTH_RECONNECT_TIME=0 #i dont think this is necessary it seem like more a behaviour detectotion is happening rother than from the computer it

# Typing speed (words per minute) when typing the query into the search box.
# 0 = instant (default, current behaviour). Any value > 0 types char-by-char at
# roughly that WPM (assuming ~5 chars per word). e.g. 60 ~= human-ish speed.
TYPING_WPM=100 # for me 100 in 7 minutes of constant searching # 200 is like 3 mintutes it start to block the completion when typing

# Which search engine the search_google tool uses under the hood.
# Options: google (default) | bing | brave | duckduckgo
SEARCH_ENGINE=yahoo
